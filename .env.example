# ============================================================
# Dyno Race — variáveis de ambiente
# Copie este arquivo para .env e ajuste o que quiser.
# `make install` já faz essa cópia automaticamente se .env não existir.
# ============================================================


# ----- Jogo: pontuação e troféus --------------------------------
# Pontos ganhos a cada obstáculo (cacto/pássaro) ultrapassado.
POINTS_PER_OBSTACLE=10

# Base dos troféus — múltiplos: TROPHY_BASE * 2^n
# Default 8 → troféus em 8, 16, 32, 64, 128, 256, 512…
# (analogia divertida: igual potências de 2 da memória RAM)
TROPHY_BASE=8


# ----- Jogo: dificuldade ----------------------------------------
# Velocidade inicial do mundo (px/frame). Quanto maior, mais difícil de cara.
GAME_SPEED_INITIAL=5

# Velocidade máxima que o mundo atinge ao acelerar com o tempo.
GAME_SPEED_MAX=100


# ----- IA: NEAT -------------------------------------------------
# Tamanho da população em cada geração.
# O .env sobrescreve o `pop_size` do arquivo src/neat_config/neat-config.ini.
POPULATION_SIZE=50

# Pausa (em segundos) entre gerações — tempo da tela "Geração X encerrada".
# Aumente pra explicar ao vivo na mentoria; diminua pra treinar mais rápido.
AUTO_RESTART_DELAY=5


# ----- Janelas --------------------------------------------------
# Janela principal do jogo.
WINDOW_WIDTH=1024
WINDOW_HEIGHT=768

# Janela secundária com a visualização da rede neural (modo IA).
BRAIN_WINDOW_WIDTH=1024
BRAIN_WINDOW_HEIGHT=768


# ----- Logs -----------------------------------------------------
# Nível de log: DEBUG | INFO | WARNING | ERROR
# DEBUG mostra eventos por geração/checkpoint; INFO é o padrão recomendado.
LOG_LEVEL=INFO

# Intervalo de amostragem do painel CPU/RAM da janela do cérebro, em segundos.
STATS_SAMPLE_INTERVAL=1.0

# ============================================================
# Dyno Race — variáveis de ambiente
# Copie este arquivo para .env e ajuste o que quiser.
# `make install` já faz essa cópia automaticamente se .env não existir.
# ============================================================


# ############################################################
# # SEÇÃO 1 — CONFIG SIMPLES (ajustes rápidos)
# ############################################################

# ----- Jogo: pontuação e troféus --------------------------------
# Pontos ganhos a cada obstáculo (cacto/pássaro) ultrapassado.
POINTS_PER_OBSTACLE=10

# Base dos troféus — múltiplos: TROPHY_BASE * 2^n
# Default 8 → troféus em 8, 16, 32, 64, 128, 256, 512…
# (analogia divertida: igual potências de 2 da memória RAM)
TROPHY_BASE=8


# ----- Jogo: dificuldade ----------------------------------------
# Velocidade inicial do mundo (px/frame). Quanto maior, mais difícil de cara.
GAME_SPEED_INITIAL=5

# Velocidade máxima que o mundo atinge ao acelerar com o tempo.
GAME_SPEED_MAX=45


# ----- IA: NEAT (básico) ---------------------------------------
# Tamanho da população em cada geração.
# O .env sobrescreve o `pop_size` do arquivo src/neat_config/neat-config.ini.
POPULATION_SIZE=80

# Pausa (em segundos) entre gerações — tempo da tela "Geração X encerrada".
# Aumente pra ter mais tempo entre uma gen e outra; diminua pra treinar mais rápido.
AUTO_RESTART_DELAY=6


# ----- Janelas --------------------------------------------------
# Janela principal do jogo.
WINDOW_WIDTH=1024
WINDOW_HEIGHT=768

# Janela secundária com a visualização da rede neural (modo IA).
BRAIN_WINDOW_WIDTH=1024
BRAIN_WINDOW_HEIGHT=768


# ----- Logs -----------------------------------------------------
# Nível de log: DEBUG | INFO | WARNING | ERROR
# DEBUG mostra eventos por geração/checkpoint; INFO é o padrão recomendado.
LOG_LEVEL=INFO

# Intervalo de amostragem do painel CPU/RAM da janela do cérebro, em segundos.
STATS_SAMPLE_INTERVAL=1.0


# ############################################################
# # SEÇÃO 2 — CONFIG AVANÇADA (NEAT fino)
# ############################################################
# Tudo aqui sobrescreve o src/neat_config/neat-config.ini sem precisar
# editar código. DESCOMENTE pra ativar; comentado = mantém o default do .ini.
# Os defaults mostrados batem com o .ini atual.

# ----- Especiação ------------------------------------------------
# Distância genética máxima pra dois genomas serem da mesma espécie.
# Maior = menos espécies (mais genomas agrupados juntos).
# NEAT_COMPATIBILITY_THRESHOLD=3.0

# Quantas gerações uma espécie pode ficar sem melhorar antes de morrer.
# NEAT_MAX_STAGNATION=20

# Número de espécies "elite" que sobrevivem mesmo se estagnarem.
# Protege diversidade. Inteiro.
# NEAT_SPECIES_ELITISM=2


# ----- Reprodução ------------------------------------------------
# Quantos melhores genomas de cada espécie passam intactos pra próxima geração.
# Inteiro. 0 = sem elitismo (só filhos por crossover/mutação).
# NEAT_ELITISM=2

# Fração (0–1) dos genomas que sobrevivem por geração pra reproduzir.
# Menor = mais seleção agressiva.
# NEAT_SURVIVAL_THRESHOLD=0.2


# ----- Mutação de topologia (estrutura da rede) ---------------------
# Probabilidade (0–1) de adicionar/remover um nó oculto a cada reprodução.
# Maior = redes crescem/encolhem mais rápido (mais exploração, menos estável).
# NEAT_NODE_ADD_PROB=0.2
# NEAT_NODE_DELETE_PROB=0.2

# Probabilidade (0–1) de adicionar/remover uma conexão a cada reprodução.
# NEAT_CONN_ADD_PROB=0.5
# NEAT_CONN_DELETE_PROB=0.5


# ----- Mutação de pesos das conexões -----------------------------
# Probabilidade (0–1) de cada peso ser perturbado por geração.
# Alto = aprendizado rápido porém mais ruído.
# NEAT_WEIGHT_MUTATE_RATE=0.8

# Magnitude da perturbação (desvio-padrão do ruído gaussiano somado ao peso).
# NEAT_WEIGHT_MUTATE_POWER=0.5
